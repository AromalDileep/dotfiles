layout {
    background-color "transparent"

    focus-ring {
        active-color   "#bccf81"
        inactive-color "#909283"
        urgent-color   "#ffb4ab"
    }

    border {
        active-color   "#bccf81"
        inactive-color "#909283"
        urgent-color   "#ffb4ab"
    }

    shadow {
        color "#00000070"
    }

    tab-indicator {
        active-color   "#bccf81"
        inactive-color "#909283"
        urgent-color   "#ffb4ab"
    }

    insert-hint {
        color "#bccf8180"
    }
}

recent-windows {
    highlight {
        active-color   "#3e4c0c"
        urgent-color   "#ffb4ab"
    }
}
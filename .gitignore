# Editor / backup files
*.save

# Neovim generated files
nvim/.config/nvim/lazy-lock.json
nvim/.config/nvim/.neoconf.json

# Runtime / cache (prevent future accidents)
.cache/
.state/
.local/

# OS junk
.DS_Store
Thumbs.db

# Auto-generated theme/color files (change on wallpaper switch)
ghostty/.config/ghostty/config-dankcolors
kitty/.config/kitty/dank-tabs.conf
kitty/.config/kitty/dank-theme.conf
niri/.config/niri/dms/colors.kdl

# Generated by theme / wallpaper switching (DO NOT TRACK)
wezterm/.config/wezterm/colors/*.toml

fuzzel/.config/fuzzel/fuzzel_theme.ini

# Niri dynamic module state (runtime, auto-generated)
niri/.config/niri/dms/

